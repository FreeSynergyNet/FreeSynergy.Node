---
# ansible-lint configuration for FSN Platform

profile: min

# Module playbooks are included task files, not standalone playbooks.
kinds:
  - tasks: "**/modules/**/playbooks/*.yml"
  - tasks: "**/playbooks/tasks/*.yml"

# Exclude module data files, project configs, and virtual paths.
# Virtual paths ending in /tasks/ are artifacts of ansible-lint resolving
# "{{ playbook_dir }}/tasks/" from within a task file. At runtime,
# playbook_dir resolves to the main playbooks/ directory correctly.
exclude_paths:
  - projects/
  - hosts/
  - .yamllint.yml
  - "**/tasks/tasks/"
  - "**playbooks/tasks/tasks/"
  - "**/mail/stalwart/playbooks/tasks/"
  - "**/proxy/zentinel/playbooks/tasks/"
