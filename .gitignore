# FSN Platform – Git Ignore

# Project instance data (secrets + volumes)
projects/*/configs/
projects/*/data/

# Host files (each deployment has its own)
# Only example.host.yml is tracked
# See hosts/.gitignore

# Internal development log (Claude Code sessions)
CHANGELOG.md

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
