# ==============================================================================
# OpenTelemetry Collector Configuration – FSN Platform
# ==============================================================================
#
# Collects three signal types from all platform containers:
#
#   1. LOGS     – from Podman journal (journald receiver)
#   2. METRICS  – from Podman container stats (docker_stats receiver)
#   3. TRACES   – from applications via OTLP (otlp receiver)
#
# Everything is sent to OpenObserver via OTLP HTTP exporter.
# ==============================================================================

receivers:
  # --------------------------------------------------------------------------
  # 1. Container logs via Podman/journald
  # --------------------------------------------------------------------------
  journald:
    directory: /var/log/journal
    units:
{% for service in project_services | default([]) %}
      - {{ service.instance_name }}
{% endfor %}
    priority: info

  # --------------------------------------------------------------------------
  # 2. Container metrics via Podman socket (Docker Stats API compatible)
  # --------------------------------------------------------------------------
  docker_stats:
    endpoint: unix:///var/run/docker.sock
    collection_interval: 30s
    timeout: 10s
    metrics:
      container.cpu.usage.total:
        enabled: true
      container.memory.usage.total:
        enabled: true
      container.memory.usage.limit:
        enabled: true
      container.network.io.usage.rx_bytes:
        enabled: true
      container.network.io.usage.tx_bytes:
        enabled: true
      container.blockio.io_service_bytes_recursive:
        enabled: true

  # --------------------------------------------------------------------------
  # 3. Application traces + metrics + logs via OTLP
  #    (apps send directly to collector)
  # --------------------------------------------------------------------------
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
      http:
        endpoint: 0.0.0.0:4318

processors:
  # Batch for efficiency
  batch:
    timeout: 10s
    send_batch_size: 1024
    send_batch_max_size: 2048

  # Memory limiter to prevent OOM
  memory_limiter:
    check_interval: 5s
    limit_percentage: 80
    spike_limit_percentage: 25

  # Add resource attributes for FSN Platform context
  resource:
    attributes:
      - key: fsn.project
        value: "{{ project_name }}"
        action: upsert
      - key: fsn.host
        value: "{{ host_name }}"
        action: upsert
      - key: deployment.environment
        value: "{{ deployment_environment | default('production') }}"
        action: upsert

exporters:
  # Send everything to OpenObserver
  otlphttp/openobserver:
    endpoint: "http://{{ services.openobserver.container_name }}:{{ services.openobserver.port }}/api/default"
    headers:
      Authorization: "Basic {{ vault_openobserver_basic_auth_token }}"
      stream-name: "{{ otel_stream_name | default('fsn-platform') }}"

  # Debug exporter for troubleshooting (disable in production)
  # debug:
  #   verbosity: basic

extensions:
  health_check:
    endpoint: 0.0.0.0:13133

service:
  extensions: [health_check]
  pipelines:
    # Container logs -> OpenObserver
    logs:
      receivers: [journald, otlp]
      processors: [memory_limiter, resource, batch]
      exporters: [otlphttp/openobserver]

    # Container metrics -> OpenObserver
    metrics:
      receivers: [docker_stats, otlp]
      processors: [memory_limiter, resource, batch]
      exporters: [otlphttp/openobserver]

    # Application traces -> OpenObserver
    traces:
      receivers: [otlp]
      processors: [memory_limiter, resource, batch]
      exporters: [otlphttp/openobserver]
