{# Zentinel KDL configuration template
   Auto-generated by FSN Platform – do not edit manually

   Architecture:
     Internet -> Zentinel (80/443) -> services via internal Podman networks
     Internet -> Zentinel (25/587/465/993) -> Stalwart via Layer-4 TCP
     All other services: internal networks only, zero external access
#}

{# === Global settings === #}
{
    admin off
    auto_https on

{% if zentinel_acme_email is defined %}
    email {{ zentinel_acme_email }}
{% endif %}
}

{# === Layer 7 HTTPS routes (reverse proxy) === #}
{% for service in project_services | rejectattr('type', 'equalto', 'mail') %}
# === FSN-MANAGED-START: {{ service.name }} ===
{{ service.subdomain }}.{{ project_domain }} {
{% if service.auth_agent | default(false) %}
    # Forward-auth via Zentinel Auth Agent
    forward_auth {{ zentinel_auth_agent_address | default('localhost:9090') }} {
        uri /_auth/verify
        copy_headers X-Auth-User X-Auth-Email X-Auth-Groups
    }
{% endif %}
    reverse_proxy {{ service.container_name }}:{{ service.port }} {
{% if service.health_path is defined and service.health_path %}
        # Active health check
        health_uri {{ service.health_path }}
        health_port {{ service.health_port | default(service.port) }}
{% if service.health_scheme | default('http') == 'https' %}
        health_scheme https
{% endif %}
        health_interval 15s
        health_timeout 5s
{% endif %}
    }
}
{% for alias in service.aliases | default([]) %}
{{ alias }}.{{ project_domain }} {
    redir https://{{ service.subdomain }}.{{ project_domain }}{uri} permanent
}
{% endfor %}
# === FSN-MANAGED-END: {{ service.name }} ===

{% endfor %}

{# === CryptPad sandbox domain (required, separate from main) === #}
{% for service in project_services | selectattr('type', 'equalto', 'collab') %}
# === FSN-MANAGED-START: {{ service.name }}-sandbox ===
sandbox.{{ project_domain }} {
    reverse_proxy {{ service.container_name }}:{{ service.port }}
}
# === FSN-MANAGED-END: {{ service.name }}-sandbox ===

{% endfor %}

{# === Matrix .well-known delegation === #}
{# === Static sites + branding (served directly by Zentinel) === #}
# === FSN-MANAGED-START: static-sites ===
{{ project_domain }} {
    # Shared branding assets (logo, CSS, bg-pattern)
    handle /branding/* {
        root * /srv/{{ project_name }}
        file_server
    }

{% for service in project_services | selectattr('type', 'equalto', 'chat') %}
    # Matrix .well-known delegation
    handle /.well-known/matrix/* {
        reverse_proxy {{ service.container_name }}:{{ service.port }}
    }
{% endfor %}

    # Landing page (default handler)
    handle {
        root * /srv/{{ project_name }}/sites/landing
        file_server
    }
}
# === FSN-MANAGED-END: static-sites ===


{# === Layer 4 TCP routes (SMTP/IMAP via Stalwart) === #}
{% for service in project_services | selectattr('type', 'equalto', 'mail') %}
# === FSN-MANAGED-START: {{ service.name }}-tcp ===

# SMTP (port 25)
:25 {
    route {
        proxy {{ service.container_name }}:25
    }
}

# SMTP Submission (port 587)
:587 {
    route {
        proxy {{ service.container_name }}:587
    }
}

# SMTPS (port 465)
:465 {
    route {
        proxy {{ service.container_name }}:465
    }
}

# IMAPS (port 993)
:993 {
    route {
        proxy {{ service.container_name }}:993
    }
}

# Stalwart HTTPS (WebAdmin, JMAP, CalDAV, CardDAV)
{{ service.subdomain }}.{{ project_domain }} {
    reverse_proxy {{ service.container_name }}:443
}
{% for alias in service.aliases | default([]) %}
{{ alias }}.{{ project_domain }} {
    redir https://{{ service.subdomain }}.{{ project_domain }}{uri} permanent
}
{% endfor %}
# === FSN-MANAGED-END: {{ service.name }}-tcp ===

{% endfor %}
