# Tuwunel configuration
# Auto-generated by FSN Platform

[global]
server_name = "{{ vars.server_name }}"
database_path = "/var/lib/tuwunel"
port = [{{ module.port }}]
address = "0.0.0.0"

max_request_size = {{ tuwunel_max_request_size | default(20000000) }}
allow_registration = {{ tuwunel_allow_registration | default('false') }}
registration_token_required = {{ tuwunel_registration_token | default('true') }}
allow_federation = {{ tuwunel_allow_federation | default('true') }}
allow_guest_registration = false

log = "{{ tuwunel_log_level | default('info') }}"

# .well-known delegation
[global.well_known]
client = "https://{{ service_domain }}"
server = "{{ service_domain }}:443"

{% if tuwunel_element_call_url is defined %}
# Element Call / MatrixRTC
[[global.well_known.rtc_transports]]
type = "livekit"
url = "{{ tuwunel_element_call_url }}"
{% endif %}

{% if services.kanidm is defined %}
# SSO/OIDC Identity Provider (Kanidm)
[[global.idp]]
brand = "{{ tuwunel_sso_brand | default('kanidm') }}"
client_id = "{{ vault_tuwunel_oidc_client_id | default('tuwunel') }}"
client_secret = "{{ vault_tuwunel_oidc_client_secret }}"
callback_url = "https://{{ service_domain }}/_matrix/client/r0/login/sso/redirect"
issuer = "https://{{ services.kanidm.domain }}/oauth2/openid/{{ vault_tuwunel_oidc_client_id | default('tuwunel') }}"
scopes = ["openid", "profile", "email"]
{% endif %}
