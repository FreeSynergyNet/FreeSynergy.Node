# Kanidm server configuration
# Auto-generated by FSN Platform
# Official docs: https://kanidm.github.io/kanidm/stable/server_configuration.html

# Config file version (required)
version = "2"

# Webserver bind address – Zentinel proxies to this
bindaddress = "[::]:{{ module.port }}"

# LDAP bind address (optional, enable for LDAP consumers like CryptPad)
{% if kanidm_ldap_enabled | default(false) %}
ldapbindaddress = "[::]:3636"
{% endif %}

# Database path
db_path = "/data/kanidm.db"

# File system tuning (zfs or other)
db_fs_type = "{{ kanidm_db_fs_type | default('other') }}"

# Domain and origin – MUST match DNS and reverse proxy
domain = "{{ vars.domain }}"
origin = "{{ vars.origin }}"

# Role: WriteReplica (default), WriteReplicaNoUI, ReadOnlyReplica
role = "{{ kanidm_role | default('WriteReplica') }}"

# Log level
log_level = "{{ log_level | default('info') }}"

[online_backup]
path = "/data/backups/"
schedule = "{{ kanidm_backup_schedule | default('00 22 * * *') }}"
versions = {{ kanidm_backup_versions | default('7') }}

