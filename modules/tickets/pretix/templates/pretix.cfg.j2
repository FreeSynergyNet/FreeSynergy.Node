; pretix configuration
; Auto-generated by FSN Platform
; OIDC plugin: pretix-oidc (installed via Dockerfile)

[pretix]
instance_name={{ pretix_instance_name | default(project_domain + ' Tickets') }}
url=https://{{ service_domain }}
currency={{ pretix_currency | default('EUR') }}
; datadir is set via PRETIX_DATA_DIR env var

[database]
backend=postgresql
host={{ services.postgres.container_name }}
port={{ services.postgres.port }}
name={{ pretix_db_name | default('pretix') }}
user={{ vault_pretix_db_user | default('pretix') }}
password={{ vault_pretix_db_password }}

[locale]
default={{ pretix_locale | default('de') }}
timezone={{ pretix_timezone | default('Europe/Berlin') }}

[mail]
from={{ pretix_mail_from | default('tickets@' + project_domain) }}
host={{ services.stalwart.container_name | default('') }}
port={{ pretix_mail_port | default('587') }}
user={{ vault_pretix_mail_user | default('') }}
password={{ vault_pretix_mail_password | default('') }}
tls={{ pretix_mail_tls | default('on') }}

[redis]
location=redis://:{{ vault_dragonfly_password }}@{{ services.dragonfly.container_name }}:{{ services.dragonfly.port }}/4
sessions=true

[celery]
broker=redis://:{{ vault_dragonfly_password }}@{{ services.dragonfly.container_name }}:{{ services.dragonfly.port }}/5
backend=redis://:{{ vault_dragonfly_password }}@{{ services.dragonfly.container_name }}:{{ services.dragonfly.port }}/6

{% if services.kanidm is defined %}
[oidc]
; pretix-oidc plugin configuration
; Activate auth backend in pretix: pretix_oidc.auth.OIDCAuthBackend
title={{ pretix_oidc_button_label | default('Login with ' + project_domain) }}
issuer=https://{{ services.kanidm.domain }}/oauth2/openid/{{ vault_pretix_oidc_client_id | default('pretix') }}
authorization_endpoint=https://{{ services.kanidm.domain }}/ui/oauth2
token_endpoint=https://{{ services.kanidm.domain }}/oauth2/token
userinfo_endpoint=https://{{ services.kanidm.domain }}/oauth2/openid/{{ vault_pretix_oidc_client_id | default('pretix') }}/userinfo
end_session_endpoint=https://{{ services.kanidm.domain }}/ui/logout
jwks_uri=https://{{ services.kanidm.domain }}/oauth2/openid/{{ vault_pretix_oidc_client_id | default('pretix') }}/public_key.jwk
client_id={{ vault_pretix_oidc_client_id | default('pretix') }}
client_secret={{ vault_pretix_oidc_client_secret }}
scopes=openid,email,profile
unique_attribute=sub
{% endif %}
