# Vikunja configuration
# Auto-generated by FSN Platform
# OIDC must be configured here (env vars for providers are unreliable)

auth:
  local:
    enabled: {{ vikunja_local_auth | default('false') }}
  openid:
    enabled: true
    providers:
{% if services.kanidm is defined %}
      kanidm:
        name: "{{ vikunja_oidc_button_label | default('Login with ' + project_domain) }}"
        authurl: "https://{{ services.kanidm.domain }}/oauth2/openid/{{ vault_vikunja_oidc_client_id | default('vikunja') }}/"
        clientid: "{{ vault_vikunja_oidc_client_id | default('vikunja') }}"
        clientsecret: "{{ vault_vikunja_oidc_client_secret }}"
        scope: "openid email profile"
{% endif %}
