# Auto-generated by FSN Platform – do not edit manually
# Module: {{ module.name }} | Instance: {{ instance_name }}

[Unit]
Description={{ module.description }} ({{ instance_name }})
{% for dep in container_dependencies | default([]) %}
After={{ dep }}.service
Requires={{ dep }}.service
{% endfor %}

[Container]
ContainerName={{ container.name }}
Image={{ container.image }}:{{ container.image_tag }}
Network={{ project_name | lower }}.network
{% for network in container.networks %}
Network={{ network }}
{% endfor %}
{% for volume in container.volumes %}
Volume={{ volume }}
{% endfor %}
{% for port in container.published_ports %}
PublishPort={{ port }}
{% endfor %}
{% for key, value in module_environment.items() %}
Environment={{ key }}={{ value }}
{% endfor %}
{% if container.read_only | default(false) %}
ReadOnly=true
{% endif %}
{% for tmpfs in container.tmpfs | default([]) %}
Tmpfs={{ tmpfs }}
{% endfor %}
{% if container.user is defined %}
User={{ container.user }}
{% endif %}
{% if container.security_opt is defined %}
{% for opt in container.security_opt %}
SecurityLabelType={{ opt }}
{% endfor %}
{% endif %}
{% if container.ulimits is defined %}
{% for ulimit in container.ulimits %}
PodmanArgs=--ulimit {{ ulimit }}
{% endfor %}
{% endif %}
AutoUpdate=registry

# Healthcheck (Podman-level: restart on failure)
{% if container.healthcheck is defined and container.healthcheck is mapping %}
HealthCmd={{ container.healthcheck.cmd }}
HealthInterval={{ container.healthcheck.interval | default('30s') }}
HealthTimeout={{ container.healthcheck.timeout | default('5s') }}
HealthRetries={{ container.healthcheck.retries | default(3) }}
HealthStartPeriod={{ container.healthcheck.start_period | default('15s') }}
{% endif %}

[Service]
Restart=always
TimeoutStartSec=300
{% if container.healthcheck is defined and container.healthcheck is mapping %}
# Restart container if health check fails
RestartSec=10
{% endif %}

[Install]
WantedBy=default.target
