---
# FreeSynergy.Node Vault – auto-generated by install-project.yml
# ⚠  KEEP SECRET – git-ignored, chmod 600
# ⚠  Do NOT commit this file.
#
# Re-running install-project.yml will NOT overwrite this file.
# To reset secrets, delete this file and run install-project.yml again.
#
# Passwords marked "auto-generated" are random and ready to use.
# Values marked "CHANGE_ME" must be filled in before deploying.

# ── Database (shared across all postgres instances in this project) ───────────
vault_db_password: "{{ lookup('password', '/dev/null chars=ascii_letters,digits length=32') }}"

# ── Cache (shared across all dragonfly instances in this project) ─────────────
vault_cache_password: "{{ lookup('password', '/dev/null chars=ascii_letters,digits length=32') }}"

# ── DNS / ACME ────────────────────────────────────────────────────────────────
# Filled in by installer if token was provided, otherwise set manually.
vault_hetzner_dns_token: "{{ vault_hetzner_dns_token | default('CHANGE_ME') }}"
vault_cloudflare_api_token: "{{ vault_cloudflare_api_token | default('CHANGE_ME') }}"

# ── Forgejo ───────────────────────────────────────────────────────────────────
vault_forgejo_secret_key: "{{ lookup('password', '/dev/null chars=ascii_letters,digits length=64') }}"
vault_forgejo_admin_password: "CHANGE_ME"
vault_forgejo_oidc_client_id: "forgejo"
vault_forgejo_oidc_client_secret: "CHANGE_ME"   # fill after Kanidm is deployed

# ── Outline ───────────────────────────────────────────────────────────────────
vault_outline_secret_key: "{{ lookup('password', '/dev/null chars=ascii_letters,digits,!@#$%^&*() length=32') }}"
vault_outline_utils_secret: "{{ lookup('password', '/dev/null chars=ascii_letters,digits length=32') }}"
vault_outline_oidc_client_id: "outline"
vault_outline_oidc_client_secret: "CHANGE_ME"   # fill after Kanidm is deployed

# ── uMap ──────────────────────────────────────────────────────────────────────
vault_umap_secret_key: "{{ lookup('password', '/dev/null chars=ascii_letters,digits length=50') }}"

# ── Vikunja ───────────────────────────────────────────────────────────────────
vault_vikunja_jwt_secret: "{{ lookup('password', '/dev/null chars=ascii_letters,digits length=32') }}"
vault_vikunja_oidc_client_id: "vikunja"
vault_vikunja_oidc_client_secret: "CHANGE_ME"   # fill after Kanidm is deployed
# Optional – leave empty to disable mail notifications:
vault_vikunja_mailer_user: ""
vault_vikunja_mailer_password: ""

# ── OpenObserve ───────────────────────────────────────────────────────────────
vault_openobserver_admin_password: "CHANGE_ME"

# ── Pretix ────────────────────────────────────────────────────────────────────
# Optional – leave empty to disable mail:
vault_pretix_mail_user: ""
vault_pretix_mail_password: ""

# ── Zentinel / Proxy ──────────────────────────────────────────────────────────
vault_zentinel_cp_oidc_client_id: "zentinel-cp"
vault_zentinel_cp_oidc_client_secret: "CHANGE_ME"   # fill after Kanidm is deployed
vault_zentinel_auth_client_id: "zentinel-auth"
vault_zentinel_auth_client_secret: "CHANGE_ME"      # fill after Kanidm is deployed
